{%- comment %}

  Article Card
  ------------------------------------------------------------------------------

  Usage:

  {% render 'article-card',
             article: { article } - required,
             show_excerpt: { boolean } - optional, default false,
             show_tags: { boolean } - optional, default false,
             sizes: { string } - optional, default '(max-width: 1023.98px) 100vw, 33vw',
             loading: { string } - optional, default 'lazy'
  %}

{% endcomment -%}

{% if article %}
  {%- liquid
    assign card_sizes = sizes | default: '(max-width: 1023.98px) 100vw, 33vw'
    assign card_loading = loading | default: 'lazy'
    assign alt_text = article.image.alt | default: article.title | escape

    capture image_widths
      render 'image-widths', max_width: 900
    endcapture
  -%}

  <article class="flex h-full flex-col gap-y-3">
    <a href="{{ article.url }}" title="{{ article.title | escape }}">
      <div class="relative aspect-[2/3] overflow-hidden bg-[#E8E5E0]">
        {% if article.image %}
          {{
            article.image
            | image_url: width: 900
            | image_tag:
              widths: image_widths,
              sizes: card_sizes,
              loading: card_loading,
              alt: alt_text,
              class: 'h-full w-full object-cover lazy-image'
          }}
        {% endif %}
      </div>
    </a>

    <div class="flex grow flex-col gap-y-2">
      <a href="{{ article.url }}" title="{{ article.title | escape }}">
        <h3 class="text-h3 text-fg">{{ article.title }}</h3>
      </a>

      {% if show_excerpt and article.excerpt_or_content != blank %}
        <p class="text-body text-fg line-clamp-2">
          {{ article.excerpt_or_content | strip_html | truncate: 160 }}
        </p>
      {% endif %}

      {% if show_tags and article.tags.size > 0 %}
        <div class="mt-auto pt-4 flex flex-wrap gap-x-3 gap-y-1">
          {% for tag in article.tags %}
            <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="text-label text-muted">
              {{ tag }}
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </article>
{% endif %}
