{% doc %}
  Product Gallery Slideshow
  ====================================

  @param {string} slides - The slides to display - required
  @param {number} slides_count - The total number of slides - required

  @example
    {% render 'product-gallery-slideshow', slides: slides, slides_count: slides_count %}
{% enddoc %}

<div class="product-detail-gallery__slideshow relative">
  <div class="embla">
    <div class="embla__viewport">
      <div class="embla__container">
        {{ slides }}
      </div>
    </div>

    {%- comment -%} A11y pagination — sr-only, updated by existing JS {%- endcomment -%}
    <div class="sr-only" data-pagination></div>

    {%- comment -%} Visual dot pagination — bottom-left of image {%- endcomment -%}
    {% if slides_count > 1 %}
      <div class="absolute bottom-3 left-4 flex items-center gap-2" data-dots>
        {% for i in (1..slides_count) %}
          <span
            class="block w-1.5 h-1.5 {% if forloop.first %}bg-fg{% else %}bg-muted{% endif %}"
            data-dot="{{ forloop.index0 }}"
          ></span>
        {% endfor %}
      </div>
    {% endif %}

    {%- comment -%} Prev/Next buttons — hidden visually, stay in DOM for JS {%- endcomment -%}
    {% if slides_count > 1 %}
      <div class="sr-only">
        <button type="button" aria-label="Previous Image" data-previous>Back</button>
        <button type="button" aria-label="Next image" data-next>Forward</button>
      </div>
    {% endif %}
  </div>

</div>
