{% # theme-check-disable RemoteAsset %}
{% # theme-check-disable UnusedAssign %}

{% doc %}
  Product Detail Form

  @param {object} product - The product to display - required
  @param {object} [current_variant] - The current variant to display - optional

  @example
    {% render 'product-detail-form',
              product: product,
              current_variant: current_variant
    %}
{% enddoc %}

{% unless product == empty %}

  {%- liquid
    assign current_variant = current_variant | default: product.selected_or_first_available_variant
  %}

  <div
    class="h-full"
    data-component="product-detail-form"
  >
    {% form 'product', product, style: 'height: 100%' %}
      <div class="lg:sticky lg:top-[var(--chrome-height)] lg:min-h-[calc(100dvh-var(--chrome-height))] lg:flex lg:items-center lg:justify-center">
        <div class="px-4 py-6 lg:py-10 lg:px-0 lg:w-[80%] lg:max-w-[480px]">

          {%- comment -%} Breadcrumb: derived from navigation structure {%- endcomment -%}
          {%- liquid
            assign breadcrumb_col = current_collection | default: product.collections.first
            assign breadcrumb_parent = nil
            assign main_menu = linklists['main-menu']
            if breadcrumb_col and main_menu
              for link in main_menu.links
                for sublink in link.links
                  assign sub_handle = sublink.url | split: '/collections/' | last | split: '?' | first
                  if sub_handle == breadcrumb_col.handle
                    assign breadcrumb_parent = link
                    break
                  endif
                endfor
                if breadcrumb_parent
                  break
                endif
              endfor
            endif
          -%}
          {% if breadcrumb_col %}
            <nav class="mb-3" aria-label="Breadcrumb">
              <ol class="flex items-center gap-1 text-[12px] text-fg">
                {% if breadcrumb_parent and breadcrumb_parent.title != breadcrumb_col.title %}
                  <li><a href="{{ breadcrumb_parent.url }}">{{ breadcrumb_parent.title }}</a></li>
                  <li>/</li>
                {% endif %}
                <li><a href="{{ breadcrumb_col.url }}">{{ breadcrumb_col.title }}</a></li>
                <li>/</li>
                <li>{{ product.title }}</li>
              </ol>
            </nav>
          {% endif %}

          {%- comment -%} Title {%- endcomment -%}
          <h1 class="text-[20px] lg:text-[28px] font-normal text-left text-fg mb-2">
            {{ product.title }}
          </h1>

          {%- comment -%} Price {%- endcomment -%}
          <div class="text-left text-[12px] lg:text-[14px] text-fg mb-6">
            {% render 'product-detail-price',
                      product: product,
                      current_variant: current_variant
            %}
          </div>

          {%- comment -%} Description {%- endcomment -%}
          {% if product.description != blank %}
            <div class="text-[12px] text-fg mb-6 leading-relaxed">
              {{ product.description }}
            </div>
          {% endif %}

          {%- comment -%} Heel variants — sibling products with different heel heights {%- endcomment -%}
          {%- assign heel_variants = product.metafields.custom.heel_variants.value -%}
          {% if heel_variants != blank %}
            <div class="mb-6">
              <span class="text-[12px] font-medium text-fg block mb-3">Heel height</span>
              <div class="flex gap-1">
                {% for entry in heel_variants %}
                  {%- assign is_active = false -%}
                  {%- if entry.id == product.id -%}
                    {%- assign is_active = true -%}
                  {%- endif -%}
                  <a href="{{ entry.url }}" class="no-underline">
                    <div class="w-24 h-[120px] overflow-hidden bg-[#E8E5E0] {% if is_active %}ring-1 ring-fg{% endif %}">
                      {{ entry.featured_image
                        | image_url: width: 240
                        | image_tag:
                          loading: 'lazy',
                          class: 'w-full h-full object-cover',
                          widths: '240',
                          sizes: '96px'
                      }}
                    </div>
                  </a>
                {% endfor %}
              </div>
            </div>
          {% elsif product.metafields.custom.heel_height_mm != blank %}
            <div class="text-[12px] text-muted mb-6">
              Heel height: {{ product.metafields.custom.heel_height_mm | divided_by: 10.0 }} cm
            </div>
          {% endif %}

          <div itemprop="offers" itemscope itemtype="http://schema.org/Offer">
            <meta itemprop="priceCurrency" content="{{ shop.currency }}">
            <meta itemprop="price" content="{{ current_variant.price | divided_by: 100.00 }}">
            <link itemprop="availability" href="http://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}">

            {%- comment -%} Variant Picker {%- endcomment -%}
            <div
              data-component="variant-picker"
              class="flex flex-col gap-6"
              {% if product.has_only_default_variant %}
                style="display: none;"
                aria-hidden="true"
              {% endif %}
            >
              {% for option in product.options_with_values %}
                {%- liquid
                  assign option_name_handle = option.name | handle
                  assign selection_type = 'select'

                  if option_name_handle == 'color'
                    assign selection_type = 'radio'
                  endif

                  if option_name_handle == 'size'
                    assign selection_type = 'radio'
                  endif
                -%}

                <div>
                  {% render 'variant-picker-option',
                            option: option,
                            product: product,
                            selection_type: selection_type
                  %}
                </div>
              {% endfor %}
            </div>

            {%- comment -%} No-JS variant select fallback {%- endcomment -%}
            <label class="sr-only" for="no-js-variant-select">Select Variant</label>
            <select name="id" class="no-js" id="no-js-variant-select">
              {% for variant in product.variants %}
                <option
                  {% if variant == current_variant %}selected="selected"{% endif %}
                  {% unless variant.available %}disabled="disabled"{% endunless %}
                  value="{{ variant.id }}"
                >
                    {{ variant.title }}
                </option>
              {% endfor %}
            </select>

            <input type="hidden" value="1" name="quantity" />

            {%- comment -%} Add to Bag button {%- endcomment -%}
            <button
              type="submit"
              name="add"
              class="w-full h-12 bg-fg text-bg text-[12px] font-medium flex items-center justify-between px-6 mt-6 disabled:bg-muted disabled:cursor-not-allowed"
              {% if current_variant.available == false %}
                disabled="disabled"
              {% endif %}
              data-component="atc-button"
            >
              <span data-label>
                {% if current_variant.available %}
                  {{ 'app.add_to_cart' | t }}
                {% else %}
                  {{ 'app.sold_out' | t }}
                {% endif %}
              </span>
              <span data-atc-price class="font-normal">
                {{ current_variant.price | money_without_trailing_zeros }}
              </span>
            </button>

            <div>
              <div>
                {{ form | payment_terms }}
              </div>
            </div>

            {%- comment -%} Info links — open modal {%- endcomment -%}
            <div class="mt-6 flex flex-col gap-3">
              <button type="button" class="text-[14px] text-fg text-left" data-info-trigger="materials-care">Materials & Care</button>
              <button type="button" class="text-[14px] text-fg text-left" data-info-trigger="size-guide">Size Guide</button>
              <button type="button" class="text-[14px] text-fg text-left" data-info-trigger="shipping-returns">Shipping & Returns</button>
              <button type="button" class="text-[14px] text-fg text-left" data-info-trigger="payments">Payments</button>
            </div>
          </div>
        </div>
      </div>

      <script type="application/json" data-product-json>
        {% render 'product-json-lite', product: product %}
      </script>
    {% endform %}
  </div>

  {%- comment -%} Product Info Modal — tab navigation {%- endcomment -%}
  <div class="fixed inset-0 z-200 pointer-events-none" data-product-info-modal data-component="product-info-modal" role="dialog" aria-label="Product information" aria-hidden="true">
    <div class="absolute inset-0 bg-fg/30 z-0 opacity-0 transition-opacity duration-300" data-modal-backdrop></div>
    <div class="absolute right-0 top-0 bottom-0 w-full lg:w-[480px] bg-bg overflow-y-auto z-10 translate-x-full transition-transform duration-300" data-modal-panel>
      {%- comment -%} Header: close button, same height/padding as main header {%- endcomment -%}
      <div class="flex items-center justify-end container h-[var(--header-height)]">
        <button type="button" class="text-[12px] text-fg" data-modal-close>Close</button>
      </div>

      {%- comment -%} Tab navigation — vertical list {%- endcomment -%}
      <div class="flex flex-col gap-1 px-4 pb-6 border-b border-fg/10">
        <button type="button" class="text-[12px] font-medium text-fg text-left py-1" data-info-tab="materials-care">Materials & Care</button>
        <button type="button" class="text-[12px] font-normal text-muted text-left py-1" data-info-tab="size-guide">Size Guide</button>
        <button type="button" class="text-[12px] font-normal text-muted text-left py-1" data-info-tab="shipping-returns">Shipping & Returns</button>
        <button type="button" class="text-[12px] font-normal text-muted text-left py-1" data-info-tab="payments">Payments</button>
      </div>

      {%- comment -%} Tab content panels {%- endcomment -%}
      <div class="px-4 py-8">
        <div data-info-panel="materials-care">
          <h4 class="text-[14px] text-fg font-normal mb-4">Materials</h4>
          <p class="text-[12px] text-fg leading-relaxed">
            {{ product.metafields.custom.materials_care | default: 'Crafted from premium Italian calfskin leather with a leather sole. Handmade in Italy.' }}
          </p>
          <div class="border-t border-fg/10 my-6"></div>
          <h4 class="text-[14px] text-fg font-normal mb-4">Care</h4>
          <p class="text-[12px] text-fg leading-relaxed">
            Store in the provided dust bag when not in use. Avoid prolonged exposure to direct sunlight and moisture.
          </p>
        </div>
        <div data-info-panel="size-guide" class="hidden">
          <h4 class="text-[14px] text-fg font-normal mb-4">Size Guide</h4>
          <p class="text-[12px] text-fg leading-relaxed">
            Find your perfect fit. Our shoes are crafted on Italian lasts and run true to European sizing.
          </p>
        </div>
        <div data-info-panel="shipping-returns" class="hidden">
          <h4 class="text-[14px] text-fg font-normal mb-4">Shipping</h4>
          <p class="text-[12px] text-fg leading-relaxed">
            Complimentary shipping on all orders. Orders are processed within 1-2 business days.
          </p>
          <div class="border-t border-fg/10 my-6"></div>
          <h4 class="text-[14px] text-fg font-normal mb-4">Returns</h4>
          <p class="text-[12px] text-fg leading-relaxed">
            {{ product.metafields.custom.shipping_returns | default: 'Free returns within 14 days of delivery. Items must be unworn and in original packaging.' }}
          </p>
        </div>
        <div data-info-panel="payments" class="hidden">
          <h4 class="text-[14px] text-fg font-normal mb-4">Payments</h4>
          <p class="text-[12px] text-fg leading-relaxed">
            We accept Visa, Mastercard, American Express, and Klarna. All transactions are secure and encrypted.
          </p>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Info modal behavior handled by TS component (productInfoModal.ts) {%- endcomment -%}

{% endunless %}
