{%- comment -%}
  Card Grid
  Up to 4 image cards in a row, each with a label underneath.
  Desktop: 4 columns. Mobile: 2 columns.
{%- endcomment -%}

{% if section.blocks.size > 0 %}
  <section class="px-2 py-6 lg:py-10" data-section-id="{{ section.id }}">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-1">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}<a href="{{ block.settings.link }}" class="block" aria-label="{{ block.settings.label }}">{% endif %}
            <div class="aspect-[3/4] overflow-hidden bg-[#E8E5E0]">
              {% if block.settings.image %}
                {{ block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'w-full h-full object-cover',
                    sizes: '(max-width: 1023px) 50vw, 25vw',
                    alt: block.settings.label | default: ''
                }}
              {% endif %}
            </div>
            {% if block.settings.label != blank %}
              <p class="text-[12px] text-fg mt-2">{{ block.settings.label }}</p>
            {% endif %}
          {% if block.settings.link != blank %}</a>{% endif %}
        </div>
      {% endfor %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Card Grid",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Card Grid"
    }
  ]
}
{% endschema %}
