{%- comment -%}
  Hero Split Section
  Two side-by-side images, each 50vw, full viewport height.
  Each panel: clickable image with title + subtitle bottom-left.
{%- endcomment -%}

<section class="flex flex-col lg:flex-row lg:h-[calc(100dvh-var(--chrome-height))]" data-section-id="{{ section.id }}">
  {%- comment -%} Left panel {%- endcomment -%}
  <a href="{{ section.settings.left_link }}" class="relative w-full h-[calc(100dvh-var(--chrome-height))] lg:w-1/2 lg:h-full overflow-hidden block" aria-label="{{ section.settings.left_title | default: 'Shop collection' }}">
    {% if section.settings.left_image %}
      {{ section.settings.left_image
        | image_url: width: 1400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'w-full h-full object-cover',
          sizes: '50vw',
          alt: section.settings.left_title | default: ''
      }}
    {% else %}
      <div class="w-full h-full bg-[#E8E5E0]"></div>
    {% endif %}

    {% if section.settings.left_title != blank %}
      <div class="absolute bottom-6 left-2 text-bg">
        <h2 class="text-[16px] font-normal">{{ section.settings.left_title }}</h2>
        {% if section.settings.left_subtitle != blank %}
          <p class="text-[16px] mt-1">{{ section.settings.left_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}
  </a>

  {%- comment -%} Right panel {%- endcomment -%}
  <a href="{{ section.settings.right_link }}" class="relative w-full h-[100dvh] lg:w-1/2 lg:h-full overflow-hidden block" aria-label="{{ section.settings.right_title | default: 'Shop collection' }}">
    {% if section.settings.right_image %}
      {{ section.settings.right_image
        | image_url: width: 1400
        | image_tag:
          loading: 'eager',
          class: 'w-full h-full object-cover',
          sizes: '50vw',
          alt: section.settings.right_title | default: ''
      }}
    {% else %}
      <div class="w-full h-full bg-[#E8E5E0]"></div>
    {% endif %}

    {% if section.settings.right_title != blank %}
      <div class="absolute bottom-6 left-2 text-bg">
        <h2 class="text-[16px] font-normal">{{ section.settings.right_title }}</h2>
        {% if section.settings.right_subtitle != blank %}
          <p class="text-[16px] mt-1">{{ section.settings.right_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}
  </a>
</section>

{% schema %}
{
  "name": "Hero Split",
  "settings": [
    {
      "type": "header",
      "content": "Left Panel"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "left_title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "left_subtitle",
      "label": "Subtitle"
    },
    {
      "type": "url",
      "id": "left_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Right Panel"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "right_title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "right_subtitle",
      "label": "Subtitle"
    },
    {
      "type": "url",
      "id": "right_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Split"
    }
  ]
}
{% endschema %}
