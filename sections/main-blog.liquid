{% paginate blog.articles by section.settings.articles_per_page %}
  <section data-section-id="{{ section.id }}" data-section-type="blog">

    {%- comment -%} Header: blog title + tag filters {%- endcomment -%}
    <div class="layout-content-wrapper">
      <div class="container">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-baseline lg:justify-between">
          <h1 class="text-h1 text-fg">{{ blog.title }}</h1>

          {% if section.settings.show_tags and blog.all_tags.size > 0 %}
            <nav class="flex flex-wrap gap-x-4 gap-y-2" aria-label="{{ 'blogs.general.categories' | t }}">
              <a
                href="{{ blog.url }}"
                class="text-label {% if current_tags == blank %}text-fg{% else %}text-muted{% endif %}"
              >
                {{ 'blogs.general.all' | t }}
              </a>
              {% for tag in blog.all_tags %}
                {% if current_tags contains tag %}
                  <a href="{{ blog.url }}" class="text-label text-fg">{{ tag }}</a>
                {% else %}
                  <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="text-label text-muted">{{ tag }}</a>
                {% endif %}
              {% endfor %}
            </nav>
          {% endif %}
        </div>
      </div>
    </div>

    {%- comment -%} Article grid {%- endcomment -%}
    <div class="container mt-6 lg:mt-10">
      <div class="grid grid-cols-1 gap-x-4 gap-y-12 lg:grid-cols-3 lg:gap-y-16">
        {% for article in blog.articles %}
          {%- liquid
            if forloop.index <= 3
              assign card_loading = 'eager'
            else
              assign card_loading = 'lazy'
            endif
          -%}

          {% render 'article-card',
                    article: article,
                    show_excerpt: section.settings.show_excerpt,
                    show_tags: section.settings.show_tags,
                    loading: card_loading
          %}
        {% endfor %}
      </div>
    </div>

    {%- comment -%} Pagination {%- endcomment -%}
    {% if paginate.pages > 1 %}
      <div class="container mt-8 lg:mt-12">
        <div class="flex justify-center">
          {% if paginate.next.is_link %}
            <a href="{{ paginate.next.url }}" class="text-label text-fg">
              {{ 'blogs.general.load_more' | t }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}

  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Blog - Main",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tag filters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show article excerpts",
      "default": true
    }
  ]
}
{% endschema %}
