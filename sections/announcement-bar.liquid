<div
  data-section-id="{{ section.id }}"
  data-section-type="announcement-bar"
  class="bg-fg text-bg"
  role="status"
  aria-live="polite"
>
  <div class="flex items-center justify-center h-[35px]">
    <p class="text-label" style="font-size: 10px;">
      {{ section.settings.text | default: 'Complimentary shipping on all orders' }}
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Complimentary shipping on all orders"
    }
  ]
}
{% endschema %}
