{% # theme-check-disable RemoteAsset %}

<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <link rel="canonical" href="{{ canonical_url }}">

    {%- comment -%}
      LCP preload for PDP hero image. Tells the browser to fetch the
      product's featured image immediately instead of waiting for HTML
      parse + render-blocking CSS to discover the <img>. Mobile LCP win.
    {%- endcomment -%}
    {% if template.name == 'product' and product.featured_image %}
      <link
        rel="preload"
        as="image"
        href="{{ product.featured_image | image_url: width: 800 }}"
        imagesrcset="
          {{ product.featured_image | image_url: width: 400 }} 400w,
          {{ product.featured_image | image_url: width: 600 }} 600w,
          {{ product.featured_image | image_url: width: 800 }} 800w,
          {{ product.featured_image | image_url: width: 1200 }} 1200w
        "
        imagesizes="(max-width: 1023px) 100vw, 50vw"
        fetchpriority="high"
      >
    {% endif %}

    {% render 'head-favicon' %}
    {% render 'head-meta-title' %}
    {% render 'head-meta-tags' %}
    {% render 'head-font-face' %}

    {{ 'app.bundle.css' | asset_url | stylesheet_tag }}

    {% render 'head-scripts' %}

    {{ content_for_header }}
  </head>

  {% capture body_class %}
    template-{{ template.name | handle }}
    {% if template.suffix != blank %} template-{{ template.name | append: '-' | append: template.suffix | handle }} {% endif %}
  {% endcapture %}

  <body id="{{ page_title | handle }}" class="{{ body_class | strip | strip_newlines }}">
    <a class="z-(--z-skip) sr-only focus:not-sr-only" href="#view-container">
      {{ 'accessibility.skip_to_content' | t }}
    </a>

    {% section 'announcement-bar' %}
    {% section 'header' %}
    {% section 'mobile-menu' %}

    <div class="flex flex-col">
      <main id="view-container" class="min-h-[100lvh]" role="main" data-taxi>
        <div data-taxi-view>
          {{ content_for_layout }}
        </div>
      </main>

      {% section 'footer' %}
    </div>

    {% section 'ajax-cart' %}

    <ul hidden>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>
  </body>
</html>
